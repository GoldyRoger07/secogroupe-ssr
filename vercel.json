{
  "version": 2,
  "public": true,
  "name": "secogroupe-ssr-vercel",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/secogroupe-ssr/**"
    }
  }
}
